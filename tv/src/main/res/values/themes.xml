<resources>
    <!-- Use MaterialComponents.NoActionBar - it is stable and safe -->
    <style name="Theme.Sanchitra" parent="Theme.MaterialComponents.NoActionBar">
        <!-- Core Fullscreen Flags -->
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowActionBar">false</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowContentOverlay">@null</item>

        <!-- This forces the status bar area to be invisible/transparent -->
        <item name="android:windowTranslucentStatus">true</item>
        <item name="android:windowBackground">@android:color/black</item>

        <item name="android:windowAllowReturnTransitionOverlap">true</item>
        <item name="android:windowAllowEnterTransitionOverlap">true</item>
    </style>

    <style name="Theme.MaterialSpinner" parent="Theme.MaterialComponents.DayNight">
        <!-- Add any specific spinner items here if needed -->
    </style>

    <!-- Splash Screen Theme (This stays the same) -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@android:color/black</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_play_circle</item>
        <item name="postSplashScreenTheme">@style/Theme.Sanchitra</item>

        <!-- Ensure splash also hides the title -->
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
    </style>
</resources>